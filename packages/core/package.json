{
  "name": "@paretojs/core",
  "version": "3.0.6",
  "homepage": "https://paretojs.tech/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/childrentime/pareto.git",
    "directory": "packages/core"
  },
  "keywords": [
    "react",
    "ssr",
    "framework",
    "server side rendering",
    "client navigation"
  ],
  "description": "SSR React framework with client-side navigation",
  "bugs": {
    "url": "https://github.com/childrentime/pareto/issues"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./store": {
      "types": "./dist/store/index.d.ts",
      "import": "./dist/store/index.mjs",
      "require": "./dist/store/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.mjs",
      "require": "./dist/node.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    }
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "pareto": "dist/cli.mjs"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/serialize-javascript": "^5.0.4",
    "postcss": "^8.5.3",
    "vitest": "^3.1.1"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.5.0",
    "cac": "^6.7.14",
    "immer": "^10.1.1",
    "serialize-javascript": "^6.0.2",
    "vite": "^7.0.0"
  }
}
